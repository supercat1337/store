{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "resolveJsonModule": true,
        "target": "ESNext",
        "module": "NodeNext",
        "noEmit": true,
        "lib": ["DOM", "ES2020"],
        "moduleResolution": "NodeNext",
        "paths": {
            "@supercat1337/store": ["./src/index.js"],
            "@supercat1337/store/*": ["./src/*"]
        }
    },
    "include": ["src/**/*", "examples/**/*"]
}
